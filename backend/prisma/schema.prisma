// This is your Prisma schema file
// Cuantive - SaaS Control de Flotas
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── CATÁLOGOS GLOBALES ────────────────────────────────────────────────────

model FuelType {
  id         Int       @id @default(autoincrement()) @db.UnsignedTinyInt
  name       String    @unique @db.VarChar(50)
  unit       FuelUnit  @default(litros)
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now()) @map("created_at")

  vehicles   Vehicle[]
  fuelLoads  FuelLoad[]

  @@map("fuel_types")
}

model VehicleType {
  id         Int       @id @default(autoincrement()) @db.UnsignedTinyInt
  name       String    @unique @db.VarChar(60)
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now()) @map("created_at")

  vehicles   Vehicle[]

  @@map("vehicle_types")
}

// ─── TENANT PRINCIPAL ─────────────────────────────────────────────────────

model Company {
  id          String    @id @db.Char(36)
  name        String    @db.VarChar(120)
  tradeName   String?   @map("trade_name") @db.VarChar(120)
  rut         String?   @unique @db.VarChar(20)
  logo        String?   @db.VarChar(512)
  address     String?   @db.VarChar(255)
  city        String?   @db.VarChar(80)
  phone       String?   @db.VarChar(30)
  email       String?   @db.VarChar(120)
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  users                User[]
  vehicles             Vehicle[]
  drivers              Driver[]
  fuelLoads            FuelLoad[]
  maintenances         Maintenance[]
  alerts               Alert[]
  alertNotifications   AlertNotification[]
  alertConfigs         AlertConfig[]
  settings             Settings?
  files                File[]
  refreshTokens        RefreshToken[]
  vehicleDocuments     VehicleDocument[]
  turnos               Turno[]
  siniestros           Siniestro[]
  satisfacciones       Satisfaccion[]

  @@index([active])
  @@map("companies")
}

// ─── USUARIOS ─────────────────────────────────────────────────────────────

model User {
  id           String    @id @db.Char(36)
  companyId    String?   @map("company_id") @db.Char(36)
  name         String    @db.VarChar(100)
  email        String    @unique @db.VarChar(120)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  role         UserRole  @default(admin)
  active       Boolean   @default(true)
  lastLogin    DateTime? @map("last_login")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")
  canDownloadMetrics  Boolean   @default(false) @map("can_download_metrics")

  company       Company?       @relation(fields: [companyId], references: [id])
  refreshTokens RefreshToken[]
  files         File[]

  @@index([companyId])
  @@index([role])
  @@index([companyId, active])
  @@map("users")
}

// ─── ARCHIVOS ─────────────────────────────────────────────────────────────

model File {
  id           String   @id @db.Char(36)
  companyId    String   @map("company_id") @db.Char(36)
  uploadedBy   String?  @map("uploaded_by") @db.Char(36)
  originalName String   @map("original_name") @db.VarChar(255)
  storedName   String   @map("stored_name") @db.VarChar(255)
  mimeType     String   @map("mime_type") @db.VarChar(100)
  sizeBytes    Int      @default(0) @map("size_bytes") @db.UnsignedInt
  storagePath  String   @map("storage_path") @db.VarChar(512)
  createdAt    DateTime @default(now()) @map("created_at")

  company      Company  @relation(fields: [companyId], references: [id])
  user         User?    @relation(fields: [uploadedBy], references: [id])

  fuelLoadReceipt    FuelLoad[]    @relation("FuelLoadReceipt")
  maintenanceReceipt Maintenance[] @relation("MaintenanceReceipt")
  siniestroImage     Siniestro[]   @relation("SiniestroImage")
  satisfaccionImage  Satisfaccion[] @relation("SatisfaccionImage")

  @@index([companyId])
  @@map("files")
}

// ─── VEHÍCULOS ─────────────────────────────────────────────────────────────

model Vehicle {
  id                   String    @id @db.Char(36)
  companyId            String    @map("company_id") @db.Char(36)
  vehicleTypeId        Int?      @map("vehicle_type_id") @db.UnsignedTinyInt
  fuelTypeId           Int?      @map("fuel_type_id") @db.UnsignedTinyInt
  plate                String    @db.VarChar(20)
  name                 String?   @db.VarChar(100)
  brand                String?   @db.VarChar(60)
  model                String?   @db.VarChar(60)
  year                 Int?      @db.UnsignedSmallInt
  color                String?   @db.VarChar(40)
  coachNumber          String?   @map("coach_number") @db.VarChar(20)
  vin                  String?   @db.VarChar(30)
  currentOdometer      Int       @default(0) @map("current_odometer") @db.UnsignedInt
  efficiencyReference  Decimal?  @map("efficiency_reference") @db.Decimal(6, 2)
  active               Boolean   @default(true)
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  deletedAt            DateTime? @map("deleted_at")

  company          Company      @relation(fields: [companyId], references: [id])
  vehicleType      VehicleType? @relation(fields: [vehicleTypeId], references: [id])
  fuelType         FuelType?    @relation(fields: [fuelTypeId], references: [id])
  fuelLoads        FuelLoad[]
  maintenances     Maintenance[]
  alerts           Alert[]
  alertNotifs      AlertNotification[]
  vehicleDocuments VehicleDocument[]
  drivers          VehicleDriver[]
  turnos           Turno[]
  siniestros       Siniestro[]
  satisfacciones   Satisfaccion[]

  @@unique([companyId, plate])
  @@index([companyId, active])
  @@map("vehicles")
}

// ─── CONDUCTORES ──────────────────────────────────────────────────────────

model Driver {
  id              String    @id @db.Char(36)
  companyId       String    @map("company_id") @db.Char(36)
  name            String    @db.VarChar(80)
  lastname        String    @db.VarChar(80)
  document        String?   @db.VarChar(20)
  licenseCategory String?   @map("license_category") @db.VarChar(10)
  licenseExpiry   DateTime? @map("license_expiry") @db.Date
  phone           String?   @db.VarChar(30)
  email           String?   @db.VarChar(120)
  notes           String?   @db.Text
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  company      Company             @relation(fields: [companyId], references: [id])
  fuelLoads    FuelLoad[]
  alerts       Alert[]
  alertNotifs  AlertNotification[]
  vehicles     VehicleDriver[]
  turnos       Turno[]
  siniestros   Siniestro[]

  @@unique([companyId, document])
  @@index([companyId, active])
  @@index([licenseExpiry])
  @@map("drivers")
}

// ─── ASIGNACIÓN VEHÍCULO–CONDUCTOR ───────────────────────────────────────

model VehicleDriver {
  vehicleId  String   @map("vehicle_id") @db.Char(36)
  driverId   String   @map("driver_id")  @db.Char(36)
  assignedAt DateTime @default(now()) @map("assigned_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driver  Driver  @relation(fields: [driverId],  references: [id], onDelete: Cascade)

  @@id([vehicleId, driverId])
  @@index([driverId])
  @@map("vehicle_drivers")
}

// ─── CARGAS DE COMBUSTIBLE ────────────────────────────────────────────────

model FuelLoad {
  id          String    @id @db.Char(36)
  companyId   String    @map("company_id") @db.Char(36)
  vehicleId   String    @map("vehicle_id") @db.Char(36)
  driverId    String?   @map("driver_id") @db.Char(36)
  fuelTypeId  Int?      @map("fuel_type_id") @db.UnsignedTinyInt
  date        DateTime
  litersOrKwh Decimal   @map("liters_or_kwh") @db.Decimal(10, 3)
  unitPrice   Decimal?  @map("unit_price") @db.Decimal(10, 4)
  priceTotal  Decimal?  @map("price_total") @db.Decimal(12, 2)
  odometer    Int?      @db.UnsignedInt
  kmPerUnit   Decimal?  @map("km_per_unit") @db.Decimal(8, 2)
  station     String?   @db.VarChar(120)
  receiptFile String?   @map("receipt_file") @db.Char(36)
  notes       String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  company  Company   @relation(fields: [companyId], references: [id])
  vehicle  Vehicle   @relation(fields: [vehicleId], references: [id])
  driver   Driver?   @relation(fields: [driverId], references: [id])
  fuelType FuelType? @relation(fields: [fuelTypeId], references: [id])
  file     File?     @relation("FuelLoadReceipt", fields: [receiptFile], references: [id])

  @@index([companyId, date])
  @@index([vehicleId, date])
  @@map("fuel_loads")
}

// ─── MANTENIMIENTOS ────────────────────────────────────────────────────────

model Maintenance {
  id              String    @id @db.Char(36)
  companyId       String    @map("company_id") @db.Char(36)
  vehicleId       String    @map("vehicle_id") @db.Char(36)
  type            String    @db.VarChar(100) @default("preventivo")
  status          String    @db.VarChar(30) @default("completed")
  description     String    @db.VarChar(255)
  date            DateTime  @db.Date
  odometer        Int?      @db.UnsignedInt
  cost            Decimal?  @db.Decimal(12, 2)
  nextOdometer    Int?      @map("next_service_km") @db.UnsignedInt
  nextDate        DateTime? @map("next_service_date") @db.Date
  workshopName    String?   @map("provider") @db.VarChar(120)
  notes           String?         @db.Text
  receiptFile     String?         @map("receipt_file") @db.Char(36)
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])
  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  file    File?   @relation("MaintenanceReceipt", fields: [receiptFile], references: [id])

  @@index([companyId, date])
  @@index([vehicleId, date])
  @@index([nextDate])
  @@map("maintenance")
}

// ─── ALERTAS ──────────────────────────────────────────────────────────────

model Alert {
  id            String    @id @db.Char(36)
  companyId     String    @map("company_id") @db.Char(36)
  vehicleId     String?   @map("vehicle_id") @db.Char(36)
  driverId      String?   @map("driver_id") @db.Char(36)
  name          String    @db.VarChar(100)
  channel       String    @default("in_app") @db.VarChar(20)
  type          AlertType
  threshold     Decimal?  @db.Decimal(10, 2)
  thresholdUnit String?   @map("threshold_unit") @db.VarChar(30)
  message       String?   @db.VarChar(255)
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  company       Company             @relation(fields: [companyId], references: [id])
  vehicle       Vehicle?            @relation(fields: [vehicleId], references: [id])
  driver        Driver?             @relation(fields: [driverId], references: [id])
  notifications AlertNotification[]

  @@index([companyId, type, active])
  @@map("alerts")
}

model AlertNotification {
  id         String        @id @db.Char(36)
  companyId  String        @map("company_id") @db.Char(36)
  alertId    String?       @map("alert_id") @db.Char(36)
  vehicleId  String?       @map("vehicle_id") @db.Char(36)
  driverId   String?       @map("driver_id") @db.Char(36)
  type       String        @db.VarChar(60)
  severity   AlertSeverity @default(medium)
  message    String        @db.Text
  metadata   Json?
  readAt     DateTime?     @map("read_at")
  resolvedAt DateTime?     @map("resolved_at")
  createdAt  DateTime      @default(now()) @map("created_at")

  company Company  @relation(fields: [companyId], references: [id])
  alert   Alert?   @relation(fields: [alertId], references: [id])
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])
  driver  Driver?  @relation(fields: [driverId], references: [id])

  @@index([companyId, readAt])
  @@index([companyId, type, vehicleId, resolvedAt])
  @@map("alert_notifications")
}

// AlertConfig: per-company, per-alert-type configuration
model AlertConfig {
  id            String    @id @db.Char(36)
  companyId     String    @map("company_id") @db.Char(36)
  alertType     AlertType @map("alert_type")
  enabled       Boolean   @default(true)
  threshold     Decimal?  @db.Decimal(10, 2)
  thresholdUnit String?   @map("threshold_unit") @db.VarChar(30)
  windowDays    Int?      @map("window_days") @db.UnsignedSmallInt
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, alertType])
  @@index([companyId, enabled])
  @@map("alert_configs")
}

// ─── CONFIGURACIÓN ────────────────────────────────────────────────────────

model Settings {
  id                      String   @id @db.Char(36)
  companyId               String   @unique @map("company_id") @db.Char(36)
  fuelPrice               Decimal? @map("fuel_price") @db.Decimal(10, 4)
  gasoilPrice             Decimal? @map("gasoil_price") @db.Decimal(10, 4)
  electricityPrice        Decimal? @map("electricity_price") @db.Decimal(10, 4)
  alertDaysBeforeLicense  Int?     @default(30) @map("alert_days_before_license") @db.UnsignedSmallInt
  alertDaysBeforeMaint    Int?     @default(15) @map("alert_days_before_maint") @db.UnsignedSmallInt
  alertKmBeforeMaint      Int?     @default(500) @map("alert_km_before_maint") @db.UnsignedInt
  alertFuelExcessPct      Decimal? @default(20) @map("alert_fuel_excess_pct") @db.Decimal(5, 2)
  alertNoLoadDays         Int?     @default(7) @map("alert_no_load_days") @db.UnsignedSmallInt
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])

  @@map("settings")
}

// ─── REFRESH TOKENS ────────────────────────────────────────────────────────

model RefreshToken {
  id        String    @id @db.Char(36)
  userId    String    @map("user_id") @db.Char(36)
  companyId String?   @map("company_id") @db.Char(36)
  tokenHash String    @unique @map("token_hash") @db.Char(64)
  userAgent String?   @map("user_agent") @db.VarChar(255)
  ipAddress String?   @map("ip_address") @db.VarChar(45)
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id])

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────

enum UserRole {
  superroot
  admin
}

enum FuelUnit {
  litros
  kwh
}

// MaintenanceType enum kept for reference (type field is now String)
// preventivo | correctivo | free-text from frontend

enum AlertType {
  fuel_excess
  no_fuel_load
  maintenance_due_date
  maintenance_due_km
  maintenance_overdue
  no_maintenance
  odometer_mismatch
  license_expiry
  vehicle_document_expiry
  custom
}

enum AlertSeverity {
  low
  medium
  high
  critical
}

enum DocumentType {
  insurance
  registration
  permit
  inspection
}

// ─── VEHICLE DOCUMENTS ────────────────────────────────────────────────────

model VehicleDocument {
  id             String       @id @db.Char(36)
  companyId      String       @map("company_id") @db.Char(36)
  vehicleId      String       @map("vehicle_id") @db.Char(36)
  documentType   DocumentType @map("document_type")
  documentNumber String?      @map("document_number") @db.VarChar(80)
  issueDate      DateTime?    @map("issue_date") @db.Date
  expirationDate DateTime?    @map("expiration_date") @db.Date
  fileUrl        String?      @map("file_url") @db.VarChar(512)
  notes          String?      @db.Text
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])
  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([companyId, expirationDate])
  @@index([vehicleId])
  @@map("vehicle_documents")
}

// ─── SINIESTROS / DAÑOS ──────────────────────────────────────────────────

model Siniestro {
  id             String    @id @db.Char(36)
  companyId      String    @map("company_id") @db.Char(36)
  vehicleId      String?   @map("vehicle_id") @db.Char(36)
  driverId       String?   @map("driver_id") @db.Char(36)
  fecha          DateTime? @db.Date
  hora           DateTime? @db.Time(0)
  observaciones  String?   @db.Text
  costo          Decimal?  @db.Decimal(12, 2)
  estado         String    @default("PENDIENTE") @db.VarChar(20)
  tipo           String?   @db.VarChar(20)
  imageFile      String?   @map("image_file") @db.Char(36)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  company  Company  @relation(fields: [companyId], references: [id])
  vehicle  Vehicle? @relation(fields: [vehicleId], references: [id])
  driver   Driver?  @relation(fields: [driverId], references: [id])
  image    File?    @relation("SiniestroImage", fields: [imageFile], references: [id])

  @@index([companyId, fecha])
  @@index([vehicleId])
  @@index([driverId])
  @@map("siniestros")
}

// ─── TURNOS ───────────────────────────────────────────────────────────────

model Turno {
  id            String   @id @db.Char(36)
  companyId     String   @map("company_id") @db.Char(36)
  vehicleId     String   @map("vehicle_id") @db.Char(36)
  driverId      String   @map("driver_id") @db.Char(36)
  shiftDate     DateTime @map("shift_date") @db.Date
  shiftNumber   Int      @map("shift_number")
  totalFichas   Decimal  @map("total_fichas") @db.Decimal(10, 2)
  kmOcupados    Decimal  @map("km_ocupados") @db.Decimal(10, 2)
  kmLibres      Decimal  @map("km_libres") @db.Decimal(10, 2)
  /// Columna calculada; se persiste para queries/KPIs
  kmTotales     Decimal  @map("km_totales") @db.Decimal(10, 2)
  notes         String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])
  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  driver  Driver  @relation(fields: [driverId], references: [id])

  @@index([companyId, shiftDate])
  @@index([vehicleId])
  @@index([driverId])
  @@map("turnos")
}

// ─── SATISFACCIÓN ─────────────────────────────────────────────────────────

model Satisfaccion {
  id            String    @id @db.Char(36)
  companyId     String    @map("company_id") @db.Char(36)
  vehicleId     String?   @map("vehicle_id") @db.Char(36)
  fecha         DateTime? @db.Date
  hora          DateTime? @db.Time(0)
  puntuacion    Int?      @db.UnsignedTinyInt
  observaciones String?   @db.Text
  imageFile     String?   @map("image_file") @db.Char(36)
  source        String    @default("manual") @db.VarChar(10)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  company Company  @relation(fields: [companyId], references: [id])
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])
  image   File?    @relation("SatisfaccionImage", fields: [imageFile], references: [id])

  @@index([companyId, fecha])
  @@index([vehicleId])
  @@map("satisfacciones")
}
